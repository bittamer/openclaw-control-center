GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_HOME_HOST=/srv/openclaw
CODEX_HOME_HOST=/srv/codex
LOCAL_TOKEN_AUTH_REQUIRED=true
LOCAL_API_TOKEN=

# Optional when your billing snapshot is not stored at /data/openclaw/subscription.json.
# OPENCLAW_SUBSCRIPTION_SNAPSHOT_PATH=/data/openclaw/billing/subscription.json

# Optional when OpenClaw uses a non-standard workspace layout.
# OPENCLAW_WORKSPACE_ROOT=/data/workspace
# OPENCLAW_AGENT_ROOT=/data/agents/main
